<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Project Manage</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Project_Manage.styles.css" asp-append-version="true" />

    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', sans-serif;
            color: #333;
        }

        /* Navbar */
        .custom-navbar {
            background-color: #1f2d3d;
            padding: 14px 0;
        }

        .navbar-brand {
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .nav-link {
            color: #d1d5db !important;
            font-weight: 500;
            transition: 0.3s ease;
        }

            .nav-link:hover {
                color: #4da3ff !important;
            }

        /* Main spacing */
        .main-container {
            margin-top: 40px;
            min-height: 75vh;
        }

        /* Footer */
        .footer {
            background-color: #ffffff;
            border-top: 1px solid #e5e7eb;
            padding: 20px 0;
            font-size: 14px;
            color: #6b7280;
        }
    </style>
</head>

<body>

    <!-- ================= NAVBAR ================= -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark corporate-navbar">
            <div class="container-fluid">

                <a class="navbar-brand fw-semibold" asp-controller="Home" asp-action="Index">
                    ProjectManage
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">
                                Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Employees" asp-action="Index">
                                Employees
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Projects" asp-action="Index">
                                Projects
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Tasks" asp-action="Index">
                                Tasks
                            </a>
                        </li>

                    </ul>

                    <partial name="_LoginPartial" />
                </div>
            </div>
        </nav>
    </header>

    <!-- ================= MAIN CONTENT ================= -->
    <div class="container main-container">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <!-- ================= FOOTER ================= -->
    <footer class="footer text-center">
        <div class="container">
            © 2026 ProjectManage. All rights reserved.
        </div>
    </footer>

    <!-- ================= SCRIPTS ================= -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>