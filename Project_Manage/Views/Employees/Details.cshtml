@model Project_Manage.Models.Employee

@{
    ViewData["Title"] = "Employee Details";
}

<div class="container mt-4">

    <div class="page-header mb-4">
        <h2 class="fw-semibold">Employee Details</h2>
        <p class="text-muted mb-0">View complete employee information.</p>
    </div>

    <div class="dashboard-card">

        <div class="row mb-3">
            <div class="col-md-3 fw-semibold text-muted">Name</div>
            <div class="col-md-9">@Model.Name</div>
        </div>

        <hr class="soft-divider" />

        <div class="row mb-3">
            <div class="col-md-3 fw-semibold text-muted">Designation</div>
            <div class="col-md-9">@Model.Designation</div>
        </div>

        <hr class="soft-divider" />

        <div class="row mb-3">
            <div class="col-md-3 fw-semibold text-muted">Gender</div>
            <div class="col-md-9">@Model.Gender</div>
        </div>

        <hr class="soft-divider" />

        <div class="row mb-3">
            <div class="col-md-3 fw-semibold text-muted">Salary</div>
            <div class="col-md-9">₹ @Model.Salary.ToString("N0")</div>
        </div>

        <hr class="soft-divider" />

        <div class="row mb-4">
            <div class="col-md-3 fw-semibold text-muted">Project</div>
            <div class="col-md-9">
                @(Model.project != null ? Model.project.Name : "-")
            </div>
        </div>

        <div class="form-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id"
               class="btn btn-primary">
                Edit
            </a>

            <a asp-action="Index"
               class="btn btn-secondary ms-2">
                Back to List
            </a>
        </div>

    </div>

</div>