@model Project_Manage.Models.Employee

@{
    ViewData["Title"] = "Delete Employee";
}

<div class="container mt-4">

    <div class="page-header mb-4">
        <h2 class="fw-semibold text-danger">Delete Employee</h2>
        <p class="text-muted mb-0">This action cannot be undone.</p>
    </div>

    <div class="dashboard-card">

        <div class="alert alert-danger mb-4">
            Are you sure you want to delete this employee?
        </div>

        <div class="row mb-3">
            <div class="col-md-3 fw-semibold text-muted">Name</div>
            <div class="col-md-9">@Model.Name</div>
        </div>

        <hr class="soft-divider" />

        <div class="row mb-3">
            <div class="col-md-3 fw-semibold text-muted">Designation</div>
            <div class="col-md-9">@Model.Designation</div>
        </div>

        <hr class="soft-divider" />

        <div class="row mb-3">
            <div class="col-md-3 fw-semibold text-muted">Gender</div>
            <div class="col-md-9">@Model.Gender</div>
        </div>

        <hr class="soft-divider" />

        <div class="row mb-3">
            <div class="col-md-3 fw-semibold text-muted">Salary</div>
            <div class="col-md-9">₹ @Model.Salary.ToString("N0")</div>
        </div>

        <hr class="soft-divider" />

        <div class="row mb-4">
            <div class="col-md-3 fw-semibold text-muted">Project</div>
            <div class="col-md-9">
                @(Model.project != null ? Model.project.Name : "-")
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <div class="form-actions">
                <button type="submit" class="btn btn-danger">
                    Delete
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary ms-2">
                    Cancel
                </a>
            </div>
        </form>

    </div>

</div>