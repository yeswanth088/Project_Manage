@model Project_Manage.Models.Employee

@{
    ViewData["Title"] = "Edit Employee";
}

<div class="container mt-4">

    <div class="page-header mb-4">
        <h2 class="fw-semibold">Edit Employee</h2>
        <p class="text-muted mb-0">Update employee information and project assignment.</p>
    </div>

    <div class="form-card">

        <form asp-action="Edit">

            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group-custom">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-control-custom" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="Designation"></label>
                <input asp-for="Designation" class="form-control-custom" />
                <span asp-validation-for="Designation" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="Gender"></label>
                <select asp-for="Gender" class="form-control-custom">
                    <option value="">-- Select Gender --</option>
                    <option>Male</option>
                    <option>Female</option>
                    <option>Other</option>
                </select>
                <span asp-validation-for="Gender" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="Salary"></label>
                <input asp-for="Salary" type="number" class="form-control-custom" />
                <span asp-validation-for="Salary" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="ProjectId">Project</label>
                <select asp-for="ProjectId"
                        class="form-control-custom"
                        asp-items="ViewBag.ProjectId">
                    <option value="">-- Select Project --</option>
                </select>
                <span asp-validation-for="ProjectId" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary-custom">
                    Save Changes
                </button>

                <a asp-action="Index" class="btn-secondary-custom">
                    Cancel
                </a>
            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}