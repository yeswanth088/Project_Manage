@model IEnumerable<Project_Manage.Models.Employee>

@{
    ViewData["Title"] = "Employees";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-semibold">Employees</h2>
            <p class="text-muted mb-0">Manage company employees and assignments.</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            + Add Employee
        </a>
    </div>

    <div class="dashboard-card">

        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Designation</th>
                    <th>Gender</th>
                    <th>Salary</th>
                    <th>Project</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">
                            No employees available.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-medium">
                                @item.Name
                            </td>

                            <td>
                                @item.Designation
                            </td>

                            <td>
                                @item.Gender
                            </td>

                            <td>
                                ₹ @item.Salary.ToString("N0")
                            </td>

                            <td>
                                @(item.project != null ? item.project.Name : "-")
                            </td>

                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary me-1">
                                    Edit
                                </a>

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-secondary me-1">
                                    Details
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-danger">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                }

            </tbody>
        </table>

    </div>

</div>