@model Project_Manage.Models.Project
@using Project_Manage.Models

@{
    ViewData["Title"] = "Edit Project";
}

<div class="container mt-4">

    <div class="page-header mb-4">
        <h2 class="fw-semibold">Edit Project</h2>
        <p class="text-muted mb-0">Update project details and status.</p>
    </div>

    <div class="form-card">

        <form asp-action="Edit">

            <input type="hidden" asp-for="Id" />

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-group-custom">
                <label asp-for="Name"></label>
                <input asp-for="Name" class="form-control-custom" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="Description"></label>
                <textarea asp-for="Description"
                          class="form-control-custom"
                          rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="Start_date">Start Date</label>
                <input asp-for="Start_date"
                       type="date"
                       class="form-control-custom" />
                <span asp-validation-for="Start_date" class="text-danger"></span>
            </div>

            <div class="form-group-custom">
                <label asp-for="Status"></label>
                <select asp-for="Status"
                        class="form-control-custom"
                        asp-items="Html.GetEnumSelectList<ProjectStatus>()">
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>

            <div class="form-actions">
                <button type="submit" class="btn-primary-custom">
                    Save Changes
                </button>

                <a asp-action="Index" class="btn-secondary-custom">
                    Cancel
                </a>
            </div>

        </form>

    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}