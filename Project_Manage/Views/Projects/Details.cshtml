@model Project_Manage.Models.Project

@{
    ViewData["Title"] = "Project Details";
}

<div class="container mt-4">

    <div class="page-header mb-4">
        <h2 class="fw-semibold">Project Details</h2>
        <p class="text-muted mb-0">View complete project information.</p>
    </div>

    <div class="dashboard-card">

        <div class="row mb-3">
            <div class="col-md-3 fw-semibold text-muted">Name</div>
            <div class="col-md-9">@Model.Name</div>
        </div>

        <hr class="soft-divider" />

        <div class="row mb-3">
            <div class="col-md-3 fw-semibold text-muted">Description</div>
            <div class="col-md-9">@Model.Description</div>
        </div>

        <hr class="soft-divider" />

        <div class="row mb-3">
            <div class="col-md-3 fw-semibold text-muted">Start Date</div>
            <div class="col-md-9">
                @Model.Start_date
            </div>
        </div>

        <hr class="soft-divider" />

        <div class="row mb-4">
            <div class="col-md-3 fw-semibold text-muted">Status</div>
            <div class="col-md-9">
                @{
                    string statusClass = Model.Status switch
                    {
                        Project_Manage.Models.ProjectStatus.Started => "status-assigned",
                        Project_Manage.Models.ProjectStatus.Dev => "status-started",
                        Project_Manage.Models.ProjectStatus.Build => "status-started",
                        Project_Manage.Models.ProjectStatus.Test => "status-started",
                        Project_Manage.Models.ProjectStatus.Deployed => "status-complete",
                        _ => ""
                    };
                }

                <span class="status-badge @statusClass">
                    @Model.Status
                </span>
            </div>
        </div>

        <div class="form-actions">
            <a asp-action="Edit" asp-route-id="@Model.Id"
               class="btn btn-primary">
                Edit
            </a>

            <a asp-action="Index"
               class="btn btn-secondary ms-2">
                Back to List
            </a>
        </div>

    </div>

</div>