@model IEnumerable<Project_Manage.Models.Project>

@{
    ViewData["Title"] = "Projects";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-semibold">Projects</h2>
            <p class="text-muted mb-0">Manage project lifecycle and deployment stages.</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            + Create Project
        </a>
    </div>

    <div class="dashboard-card">

        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Description</th>
                    <th>Start Date</th>
                    <th>Status</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>

            <tbody>

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            No projects available.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-medium">
                                @item.Name
                            </td>

                            <td>
                                @item.Description
                            </td>

                            <td>
                                @item.Start_date
                            </td>

                            <td>
                                @{
                                    string statusClass = item.Status switch
                                    {
                                        Project_Manage.Models.ProjectStatus.Started => "status-started",
                                        Project_Manage.Models.ProjectStatus.Dev => "status-assigned",
                                        Project_Manage.Models.ProjectStatus.Build => "status-assigned",
                                        Project_Manage.Models.ProjectStatus.Test => "status-started",
                                        Project_Manage.Models.ProjectStatus.Deployed => "status-complete",
                                        _ => ""
                                    };
                                }

                                <span class="status-badge @statusClass">
                                    @item.Status
                                </span>
                            </td>

                            <td class="text-end">
                                <a asp-action="Edit"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary me-1">
                                    Edit
                                </a>

                                <a asp-action="Details"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-secondary me-1">
                                    Details
                                </a>

                                <a asp-action="Delete"
                                   asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-danger">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                }

            </tbody>
        </table>

    </div>

</div>