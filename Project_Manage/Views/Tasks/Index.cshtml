@model IEnumerable<Project_Manage.Models.Task>

@{
    ViewData["Title"] = "Tasks";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-semibold">Tasks</h2>
            <p class="text-muted mb-0">Manage and monitor all assigned tasks.</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            + Create Task
        </a>
    </div>

    <div class="dashboard-card">

        <table class="table align-middle mb-0">
            <thead>
                <tr>
                    <th>Task Name</th>
                    <th>Status</th>
                    <th>Project</th>
                    <th>Employee</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>

                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">
                            No tasks available.
                        </td>
                    </tr>
                }
                else
                {
                    foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-medium">
                                @item.Name
                            </td>

                            <td>
                                @{
                                    string badgeClass = item.Status switch
                                    {
                                        Project_Manage.Models.TaskStatus.Assigned => "bg-primary",
                                        Project_Manage.Models.TaskStatus.Started => "bg-warning text-dark",
                                        Project_Manage.Models.TaskStatus.Complete => "bg-success",
                                        _ => "bg-secondary"
                                    };
                                }

                                <span class="badge @badgeClass">
                                    @item.Status
                                </span>
                            </td>

                            <td>
                                @(item.Pro != null ? item.Pro.Name : "-")
                            </td>

                            <td>
                                @(item.Emp != null ? item.Emp.Name : "-")
                            </td>

                            <td class="text-end">
                                <a asp-action="Edit" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary me-1">
                                    Edit
                                </a>

                                <a asp-action="Details" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-secondary me-1">
                                    Details
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-danger">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                }

            </tbody>
        </table>

    </div>

</div>