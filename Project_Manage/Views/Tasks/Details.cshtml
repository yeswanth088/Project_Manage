@model Project_Manage.Models.Task

@{
    ViewData["Title"] = "Task Details";
}

<div class="page-header">
    <h2>Task Details</h2>
    <p class="text-muted">View complete task information.</p>
</div>

<div class="form-card">

    <div class="detail-row">
        <strong>Name</strong>
        <span>@Model.Name</span>
    </div>

    <div class="detail-row">
        <strong>Project</strong>
        <span>@(Model.Pro != null ? Model.Pro.Name : "-")</span>
    </div>

    <div class="detail-row">
        <strong>Employee</strong>
        <span>@(Model.Emp != null ? Model.Emp.Name : "-")</span>
    </div>

    <div class="detail-row">
        <strong>Status</strong>
        @{
            string statusClass = Model.Status switch
            {
                Project_Manage.Models.TaskStatus.Assigned => "status-assigned",
                Project_Manage.Models.TaskStatus.Started => "status-started",
                Project_Manage.Models.TaskStatus.Complete => "status-complete",
                _ => ""
            };
        }

        <span class="status-badge @statusClass">
            @Model.Status
        </span>
    </div>

    <div class="form-actions mt-4">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn-primary-custom">
            Edit
        </a>

        <a asp-action="Index" class="btn-secondary-custom">
            Back
        </a>
    </div>

</div>