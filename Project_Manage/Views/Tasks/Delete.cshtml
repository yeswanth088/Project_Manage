@model Project_Manage.Models.Task

@{
    ViewData["Title"] = "Delete Task";
}

<div class="container mt-4">

    <div class="page-header mb-4">
        <h2 class="fw-semibold text-danger">Delete Task</h2>
        <p class="text-muted mb-0">This action cannot be undone.</p>
    </div>

    <div class="dashboard-card">

        <div class="alert alert-danger mb-4">
            Are you sure you want to delete this task?
        </div>

        <div class="row mb-3">
            <div class="col-md-3 fw-semibold text-muted">Task Name</div>
            <div class="col-md-9">@Model.Name</div>
        </div>

        <hr class="soft-divider" />

        <div class="row mb-3">
            <div class="col-md-3 fw-semibold text-muted">Project</div>
            <div class="col-md-9">
                @(Model.Pro != null ? Model.Pro.Name : "-")
            </div>
        </div>

        <hr class="soft-divider" />

        <div class="row mb-3">
            <div class="col-md-3 fw-semibold text-muted">Assigned Employee</div>
            <div class="col-md-9">
                @(Model.Emp != null ? Model.Emp.Name : "-")
            </div>
        </div>

        <hr class="soft-divider" />

        <div class="row mb-4">
            <div class="col-md-3 fw-semibold text-muted">Status</div>
            <div class="col-md-9">
                @{
                    string statusClass = Model.Status switch
                    {
                        Project_Manage.Models.TaskStatus.Assigned => "status-assigned",
                        Project_Manage.Models.TaskStatus.Started => "status-started",
                        Project_Manage.Models.TaskStatus.Complete => "status-complete",
                        _ => ""
                    };
                }
                <span class="status-badge @statusClass">
                    @Model.Status
                </span>
            </div>
        </div>

        <form asp-action="Delete">
            <input type="hidden" asp-for="Id" />

            <div class="form-actions">
                <button type="submit" class="btn btn-danger">
                    Delete
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary ms-2">
                    Cancel
                </a>
            </div>
        </form>

    </div>

</div>