@model Project_Manage.Models.Task

@{
    ViewData["Title"] = "Create Task";
}

<div class="container mt-4">

    <div class="mb-4">
        <h2 class="fw-semibold">Create Task</h2>
        <p class="text-muted">Assign a new task to a project and employee.</p>
        <hr class="soft-divider" />
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

            <div class="dashboard-card">

                <form asp-action="Create">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label fw-medium"></label>
                        <input asp-for="Name" class="form-control" />
                    </div>

                    <div class="mb-3">
                        <label asp-for="Project_id" class="form-label fw-medium">Project</label>
                        <select asp-for="Project_id"
                                class="form-select"
                                asp-items="ViewBag.Project_id">
                            <option value="">-- Select Project --</option>
                        </select>

                        <div id="existingTasksContainer" class="mt-2 text-info small"></div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Employee_id" class="form-label fw-medium">Employee</label>
                        <select asp-for="Employee_id"
                                class="form-select"
                                asp-items="ViewBag.Employee_id">
                            <option value="">-- Select Employee --</option>
                        </select>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Status" class="form-label fw-medium"></label>
                        <select asp-for="Status"
                                class="form-select"
                                asp-items="ViewBag.StatusList">
                            <option value="">-- Select Status --</option>
                        </select>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            Create Task
                        </button>

                        <a asp-action="Index" class="btn btn-outline-secondary">
                            Cancel
                        </a>
                    </div>

                </form>

            </div>

        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        $(document).ready(function () {
            $("#Project_id").change(function () {
                var selectedProjectId = $(this).val();
                var container = $("#existingTasksContainer");

                if (selectedProjectId) {
                    container.html("<span class='text-muted'>Loading tasks...</span>");

                    $.ajax({
                        url: '@Url.Action("GetTasksByProject", "Tasks")',
                        type: 'GET',
                        data: { projectId: selectedProjectId },
                        success: function (data) {
                            container.empty(); 

                            if (data.length > 0) {
                                var html = "<div class='mt-2 p-2 border rounded bg-light'>";
                                html += "<strong class='text-dark'>Current Tasks in this Project:</strong><ul class='mb-0 ps-3'>";
                                $.each(data, function (index, task) {
                                    html += "<li class='text-secondary'>" + task.name + " (" + task.status + ")</li>";
                                });
                                html += "</ul></div>";
                                container.html(html);
                            } else {
                                container.html("<div class='mt-2 p-2 border rounded bg-light text-muted'><em>No tasks exist for this project yet.</em></div>");
                            }
                        },
                        error: function() {
                            container.html("<span class='text-danger'>Error loading tasks.</span>");
                        }
                    });
                } else {
                    container.empty();
                }
            });
        });
    </script>
}